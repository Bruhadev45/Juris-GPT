import { chromium } from "playwright";
import fs from "fs";

const PAGES = [
  ["landing", "/"],
  ["chat_unauth", "/chat"],
  ["dashboard", "/dashboard"],
  ["dashboard_chat", "/dashboard/chat"],
  ["dashboard_contracts", "/dashboard/contracts"],
  ["dashboard_compliance", "/dashboard/compliance"],
];

const out = "/tmp/jurisgpt_screens2";
fs.mkdirSync(out, { recursive: true });

const browser = await chromium.launch();
const ctx = await browser.newContext({
  viewport: { width: 1440, height: 900 },
  deviceScaleFactor: 1,
});
const page = await ctx.newPage();

const results = [];
for (const [name, path] of PAGES) {
  const url = `http://localhost:3001${path}`;
  await page.goto(url, { waitUntil: "networkidle", timeout: 30000 });
  await page.waitForTimeout(800);

  const totalHeight = await page.evaluate(() =>
    Math.max(
      document.body.scrollHeight,
      document.documentElement.scrollHeight
    )
  );
  const viewportHeight = 900;
  const passes = Math.max(1, Math.ceil(totalHeight / viewportHeight));
  // Scroll the page incrementally to fire IntersectionObservers.
  for (let i = 0; i <= passes; i++) {
    await page.evaluate((y) => window.scrollTo({ top: y, behavior: "instant" }), i * viewportHeight);
    await page.waitForTimeout(450);
  }
  await page.evaluate(() => window.scrollTo({ top: 0, behavior: "instant" }));
  await page.waitForTimeout(500);

  const top = `${out}/${name}_top.png`;
  await page.screenshot({ path: top, fullPage: false });

  // Two more captures: midpoint and bottom
  await page.evaluate((y) => window.scrollTo({ top: y, behavior: "instant" }), Math.floor(totalHeight / 2));
  await page.waitForTimeout(500);
  const mid = `${out}/${name}_mid.png`;
  await page.screenshot({ path: mid, fullPage: false });

  await page.evaluate((y) => window.scrollTo({ top: y, behavior: "instant" }), totalHeight);
  await page.waitForTimeout(500);
  const bot = `${out}/${name}_bottom.png`;
  await page.screenshot({ path: bot, fullPage: false });

  // Full-page after we've scrolled (observers should now have fired)
  await page.evaluate(() => window.scrollTo({ top: 0, behavior: "instant" }));
  await page.waitForTimeout(400);
  const full = `${out}/${name}_full.png`;
  await page.screenshot({ path: full, fullPage: true });

  results.push({ name, url, totalHeight, top, mid, bot, full });
}
fs.writeFileSync(`${out}/summary.json`, JSON.stringify(results, null, 2));
console.log(JSON.stringify(results, null, 2));
await browser.close();
